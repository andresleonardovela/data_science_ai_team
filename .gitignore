# Virtual environment
.venv/
venv/
env/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Environment variables (never commit real credentials)
.env
.env.local
.env.*.local

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

