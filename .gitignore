mlruns/
*.pkl
*.joblib
*.h5
*.onnx
projects/*/data/raw/
projects/*/data/processed/
!projects/*/data/.gitkeep

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Secrets (never commit)
config/secrets.md
*.pem
*.key

# Quota usage tracking (local state)
.quota_usage.json
